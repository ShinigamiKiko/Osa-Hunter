# ── OSA Hunter — Configuration ────────────────────────────────
# Скопируй этот файл и заполни значения перед запуском.
#
# SESSION_SECRET — ОБЯЗАТЕЛЬНО.
# Без него приложение не запустится.
# Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   или: openssl rand -hex 32
#
SESSION_SECRET=

# NVD API key для CVSS-обогащения (опционально, но рекомендуется).
# Получить: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Порты (опционально, дефолты: 3000 / 3001)
FRONTEND_PORT=3000
BACKEND_PORT=3001

# PostgreSQL (опционально, но смени дефолтные пароли перед деплоем)
PGDATABASE=osa
PGUSER=osa
PGPASSWORD=

# GitHub token для activity-сканирования (опционально, увеличивает rate limit)
GITHUB_TOKEN=
